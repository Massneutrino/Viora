        }
      ],
      "expectedIncluded": [{ "id": "stale_positive", "minScore": 0.2, "maxScore": 0.35 }]
    },
    {
      "name": "temporal_scoring_excludes_expired_and_superseded_edges",
      "edges": [
        {
          "id": "expired_edge",
          "weight": 1,
          "confidence": 1,
          "evidenceCount": 5,
          "validUntil": "2026-06-01T00:00:00.000Z",
          "lastEvidenceAt": "2026-05-01T00:00:00.000Z",
          "decayPolicy": "linear_365d"
        },
        {
          "id": "superseded_edge",
          "weight": 1,
          "confidence": 1,
          "evidenceCount": 5,
          "supersededByEdgeId": "replacement_edge",
          "lastEvidenceAt": "2026-06-20T12:00:00.000Z",
          "decayPolicy": "linear_365d"
        }
      ],
      "expectedExcluded": [
        { "id": "expired_edge", "reason": "expired" },
        { "id": "superseded_edge", "reason": "superseded" }
      ]
    },
    {
      "name": "temporal_scoring_bounds_negative_risk_evidence",
      "edges": [
        {
          "id": "negative_risk",
          "weight": -1,
          "confidence": 1,
          "evidenceCount": 20,
          "lastEvidenceAt": "2026-06-26T12:00:00.000Z",
          "decayPolicy": "linear_365d"
        }
      ],
      "expectedIncluded": [{ "id": "negative_risk", "minScore": -1, "maxScore": -0.95 }]
    }
  ],
