{
  "name": "viora",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native operating system for flexible and temporary work",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "npm run dev --workspace @viora/api",
    "dev:site": "npm run dev --workspace @viora/site",
    "dev:web": "npm run dev --workspace @viora/web",
    "dev:admin": "npm run dev --workspace @viora/admin",
    "dev:worker-web": "npm run dev --workspace @viora/worker-web",
    "dev:mobile": "npm run dev --workspace @viora/mobile",
    "dev:mobile:secondary": "npm run dev:secondary --workspace @viora/mobile",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "benchmark:intake": "npm run build --workspace @viora/domain && npm run build --workspace @viora/agents && node scripts/benchmark-intake.mjs",
    "test:memory": "tsx scripts/smoke-memory-stack.mjs",
    "test:memory:evals": "npm run build --workspace @viora/agents && tsx scripts/test-memory-evals.mjs",
    "test:phase0": "npm run build --workspace @viora/api && tsx scripts/smoke-phase0.mjs",
    "db:generate": "npm run generate --workspace @viora/database",
    "db:migrate": "npm run migrate --workspace @viora/database",
    "db:seed": "npm run seed --workspace @viora/database",
    "db:studio": "npm run studio --workspace @viora/database"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.9.0"
}
