  "temporalScoringCases": [
    {
      "name": "temporal_scoring_includes_recent_repeated_evidence",
      "edges": [
        {
          "id": "recent_positive",
          "weight": 0.8,
          "confidence": 0.9,
          "evidenceCount": 4,
          "lastEvidenceAt": "2026-06-20T12:00:00.000Z",
          "decayPolicy": "linear_365d"
        }
      ],
      "expectedIncluded": [{ "id": "recent_positive", "minScore": 0.6, "maxScore": 1 }]
    },
    {
      "name": "temporal_scoring_decays_stale_evidence",
      "edges": [
        {
          "id": "stale_positive",
          "weight": 0.8,
          "confidence": 0.9,
          "evidenceCount": 2,
          "lastEvidenceAt": "2025-06-27T12:00:00.000Z",
