# Railway API service — copy to a local file, fill secrets, then import via
# Railway → API service → Variables → Raw Editor (or paste one-by-one).
# See docs/deploy.md for full setup. Never commit real keys to git.
#
# Quoting matches local .env: quotes only for secrets, empty placeholders,
# and VOICE_TTS_STYLE (spaces). Simple values like eleven_flash_v2_5 and v4
# work fine without quotes — "eleven_flash_v2_5" is equivalent.

# ── Infra (set in Railway dashboard) ───────────────────────────────────────
# DATABASE_URL — reference Postgres service: ${{Postgres.DATABASE_URL}}
# API_PORT — reference Railway PORT: ${{PORT}}
JWT_SECRET=replace-with-long-random-production-secret
NODE_ENV=production

# ── LLM (Google brain) ─────────────────────────────────────────────────────
AI_PROVIDER=google
AI_MODEL=
AI_MODEL_FAST=gemini-2.5-flash
AI_MODEL_INTENT=gemini-2.5-pro
GOOGLE_API_KEY=""

# ── Voice — STT (Gemini) + TTS (ElevenLabs) ─────────────────────────────────
VOICE_STT_PROVIDER=gemini
VOICE_STT_MODEL=gemini-2.5-flash
VOICE_TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="8bNue5gVKTykcmaQaZfT"
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.46
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.06
ELEVENLABS_SPEED=0.97
ELEVENLABS_SPEAKER_BOOST=false
VOICE_TTS_STYLE_VERSION=v4
VOICE_TTS_STYLE="V sounds like a sharp British staffing coordinator in her late 20s: calm, capable, concise, and quietly confident. Use modern neutral UK delivery, natural pauses, subtle downward inflection on firm statements, and extra clarity for dates, shifts, DBS, compliance, bookings, and next steps. Never sound salesy, theatrical, childish, maternal, overly cheerful, or like a generic assistant."

# ── Optional (only when deploying employer/worker apps later) ───────────────
# WEB_URL=https://your-employer-app.vercel.app
# WORKER_WEB_URL=https://your-worker-app.vercel.app
